<div class="ah-settings-wrap">
    <div class="ah-settings-topbar">
        <a href="<?php echo htmlspecialchars($this->indexUrl, ENT_QUOTES, 'UTF-8'); ?>" class="ah-back">&#8592; Back</a>
        <h1>Automation Hub Settings</h1>
    </div>

    <?php if ($this->saved): ?>
        <div class="ah-alert-success">Settings saved.</div>
    <?php endif; ?>

    <form method="post" class="ah-card">
        <div class="ah-group">
            <label>Automation Hub URL</label>
            <input type="url" name="hub_url"
                value="<?php echo htmlspecialchars($this->hubUrl, ENT_QUOTES, 'UTF-8'); ?>"
                placeholder="https://ansible.example.com" required>
            <p class="ah-hint">Base URL of your Automation Hub installation (no trailing slash).</p>
        </div>
        <div class="ah-group">
            <label>Username</label>
            <input type="text" name="hub_username"
                value="<?php echo htmlspecialchars($this->hubUsername, ENT_QUOTES, 'UTF-8'); ?>"
                placeholder="admin" required autocomplete="off">
        </div>
        <div class="ah-group">
            <label>Password<?php echo $this->hasPassword ? ' <span style="font-weight:400;color:#94a3b8">(leave blank to keep existing)</span>' : ''; ?></label>
            <input type="password" name="hub_password"
                placeholder="<?php echo $this->hasPassword ? '••••••••' : 'Enter password'; ?>"
                autocomplete="new-password">
        </div>
        <div class="ah-actions">
            <button type="submit" class="ah-btn ah-btn-primary">Save</button>
            <button type="button" class="ah-btn" onclick="testConn()">Test Connection</button>
            <span id="result" class="ah-result" style="display:none"></span>
        </div>
    </form>
</div>

<script>
async function testConn() {
    const r = document.getElementById('result');
    r.className = 'ah-result';
    r.style.display = '';
    r.textContent = 'Testing...';
    try {
        const res = await fetch(<?php echo json_encode($this->testUrl); ?>, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                hub_url: document.querySelector('[name=hub_url]').value.trim(),
                hub_username: document.querySelector('[name=hub_username]').value.trim(),
                hub_password: document.querySelector('[name=hub_password]').value,
            })
        });
        const d = await res.json();
        r.className = 'ah-result ' + (d.ok ? 'ah-ok' : 'ah-err');
        r.textContent = d.message;
    } catch (e) {
        r.className = 'ah-result ah-err';
        r.textContent = 'Request failed: ' + e.message;
    }
}
</script>
