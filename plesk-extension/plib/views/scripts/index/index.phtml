                <div id="fields" class="ah-fields"></div>
                <div class="ah-run-bar">
                    <button id="run-btn" class="ah-btn ah-btn-primary" onclick="AH.run()">&#9654; Run</button>
                    <span id="run-status"></span>
                </div>
                <div id="output" class="ah-output" style="display:none">
                    <div class="ah-output-bar">
                        <span>Output</span>
                        <span id="output-status"></span>
                    </div>
                    <pre id="output-text"></pre>
                </div>
            </div>
        </div>
    <?php endif ?>
</div>

<script>
const AH = (() => {
    const PROXY = <?php echo json_encode($this->proxyUrl); ?>;
    const HUB_BASE = <?php echo json_encode($this->hubBaseUrl); ?>;
    let form = null, fields = [], pollTimer = null, activeRunId = null;

    async function api(method, endpoint, body = null) {
        const r = await fetch(PROXY, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({method, endpoint, body}),
        });
        const d = await r.json();
        if (d.error) throw new Error(d.error);
        return d;
    }

    async function loadForms() {
        try {
            const forms = await api('GET', '/api/forms');
            renderForms(Array.isArray(forms) ? forms : []);
        } catch (e) {
            document.getElementById('forms-area').innerHTML =
                `<div class="ah-alert ah-alert-warn">Failed to load forms: ${esc(e.message)}</div>`;
        }
    }

    function renderForms(list) {
        const el = document.getElementById('forms-area');
        if (!list.length) {
            el.innerHTML = '<div class="ah-empty">No forms found. Create forms in Automation Hub first.</div>';
            return;
        }
        el.innerHTML = '<div class="ah-grid">' + list.map(f => `
            <div class="ah-card">
                ${f.image_name ? `<div class="ah-card-media"><img src="${escAttr(formImageUrl(f))}" alt="${escAttr(f.name)}"></div>` : ''}
                <div class="ah-card-name">${esc(f.name)}</div>
                <div class="ah-card-desc">${esc(f.description || '')}</div>
                <div class="ah-card-foot">
                    ${f.is_quick_action ? '<span class="ah-badge">Quick Action</span>' : '<span></span>'}
                    <button class="ah-btn ah-btn-primary" onclick="AH.open(${esc(JSON.stringify(f))})">&#9654; Run</button>
                </div>
            </div>
        `).join('') + '</div>';
    }

    async function open(f) {
        stopPoll();
        form = f;
        document.getElementById('runner-title').textContent = f.name;
        document.getElementById('fields').innerHTML = '<div class="ah-empty"><span class="ah-spinner"></span>&nbsp; Loading&hellip;</div>';
        document.getElementById('output').style.display = 'none';
        document.getElementById('run-status').textContent = '';
        document.getElementById('run-status').className = '';
        document.getElementById('run-btn').disabled = false;
        document.getElementById('runner').style.display = '';
        document.getElementById('runner').scrollIntoView({behavior:'smooth', block:'start'});

        try {
            const f2 = await api('GET', `/api/forms/${f.id}/fields`);
            fields = Array.isArray(f2) ? f2 : [];
            renderFields(fields);
        } catch (e) {
            document.getElementById('fields').innerHTML =
                `<div class="ah-alert ah-alert-warn">Failed to load fields: ${esc(e.message)}</div>`;
        }
    }

    // ── Dependency evaluation ─────────────────────────────────────────────────

    function getFieldValue(f) {
        const el = document.getElementById('f_' + f.id);
        if (!el) return '';
        return f.field_type === 'bool' ? (el.checked ? 'true' : 'false') : el.value;
    }

    function isFieldVisible(f) {
        if (!f.depends_on_name) return true;
        const parentField = fields.find(x => x.name === f.depends_on_name);
        if (!parentField) return true;
        const parent = getFieldValue(parentField);
        const val = f.depends_on_value || '';
        switch (f.depends_on_operator || 'eq') {
            case 'eq':           return parent === val;
            case 'neq':         return parent !== val;
            case 'in':           return val.split(',').map(s => s.trim()).includes(parent);
            case 'not_in':       return !val.split(',').map(s => s.trim()).includes(parent);
            case 'contains':     return parent.includes(val);
            case 'not_contains': return !parent.includes(val);
            case 'empty':        return parent === '' || parent === 'false';
            case 'not_empty':    return parent !== '' && parent !== 'false';
            default:             return parent === val;
        }
    }

    function applyVisibility() {
        for (const f of fields) {
            const wrapper = document.querySelector(`[data-fid="${CSS.escape(f.id)}"]`);
            if (wrapper) wrapper.style.display = isFieldVisible(f) ? '' : 'none';
        }
    }

    function renderFields(list) {
        const el = document.getElementById('fields');
        if (!list.length) {
            el.innerHTML = '<p style="color:#64748b;font-size:14px">No input fields. Click Run to execute immediately.</p>';
            return;
        }
        el.innerHTML = list.map(f => {
            const req = f.required ? ' <span style="color:#e11d48">*</span>' : '';
            if (f.field_type === 'bool') {
                return `<div class="ah-field" data-fid="${esc(f.id)}">
                    <div class="ah-field-bool">
                        <input type="checkbox" id="f_${f.id}" ${f.default_value === 'true' ? 'checked' : ''}>
                        <label for="f_${f.id}" style="text-transform:none;font-size:14px">${esc(f.label)}${req}</label>
                    </div>
                </div>`;
            }
            if (f.field_type === 'select') {
                let opts = [];
                try { opts = JSON.parse(f.options); } catch (_) {}
                return `<div class="ah-field" data-fid="${esc(f.id)}"><label>${esc(f.label)}${req}</label>
                    <select id="f_${f.id}">${opts.map(o =>
                        `<option value="${esc(o)}"${o === f.default_value ? ' selected' : ''}>${esc(o)}</option>`
                    ).join('')}</select></div>`;
            }
            return `<div class="ah-field" data-fid="${esc(f.id)}"><label>${esc(f.label)}${req}</label>
                <input type="${f.field_type === 'number' ? 'number' : 'text'}" id="f_${f.id}"
                    value="${esc(f.default_value)}"${f.required ? ' required' : ''}></div>`;
        }).join('');

        // Attach change listeners so dependent fields react immediately
        for (const f of list) {
            const input = document.getElementById('f_' + f.id);
            if (input) input.addEventListener('change', applyVisibility);
            if (input) input.addEventListener('input', applyVisibility);
        }
        applyVisibility();
    }

    function close() {
        stopPoll();
        document.getElementById('runner').style.display = 'none';
        form = null;
        fields = [];
    }

    async function run() {
        if (!form) return;
        stopPoll();

        const vars = {};
        for (const f of fields) {
            if (!isFieldVisible(f)) continue;
            const el = document.getElementById('f_' + f.id);
            if (!el) continue;
            const v = f.field_type === 'bool' ? (el.checked ? 'true' : 'false') : el.value.trim();
            if (f.required && v === '') {
                el.focus();
                return;
            }
            vars[f.name] = v;
        }

        document.getElementById('run-btn').disabled = true;
        setStatus('running', 'Starting...');
        const outEl = document.getElementById('output');
        const outText = document.getElementById('output-text');
        outEl.style.display = '';
        outText.textContent = '';

        try {
            const res = await api('POST', '/api/runs', {form_id: form.id, variables: vars});
            if (!res.run_id) throw new Error('This form returned no single run ID.');
            activeRunId = res.run_id;
            startPoll(res.run_id);
        } catch (e) {
            setStatus('failed', 'Error: ' + e.message);
            document.getElementById('run-btn').disabled = false;
        }
    }

    function startPoll(runId) {
        const outText = document.getElementById('output-text');
        setStatus('running', 'Running');
        document.getElementById('output-status').textContent = 'running';

        pollTimer = setInterval(async () => {
            try {
                const r = await api('GET', `/api/runs/${runId}`);
                outText.textContent = stripAnsi(r.output || '');
                outText.scrollTop = outText.scrollHeight;

                if (r.status === 'success' || r.status === 'failed') {
                    stopPoll();
                    document.getElementById('output-status').textContent = r.status;
                    setStatus(r.status, r.status.charAt(0).toUpperCase() + r.status.slice(1));
                    document.getElementById('run-btn').disabled = false;
                    activeRunId = null;
                }
            } catch (_) {}
        }, 2000);
    }

    function stopPoll(resetRun = true) {
        if (pollTimer) {
            clearInterval(pollTimer);
            pollTimer = null;
        }
        if (resetRun) {
            activeRunId = null;
        }
    }

    function setStatus(state, text) {
        const el = document.getElementById('run-status');
        el.className = 'ah-status ah-s-' + state;
        el.textContent = text;
    }

    function formImageUrl(f) {
        return `${HUB_BASE}/api/forms/${encodeURIComponent(f.id)}/image`;
    }

    function esc(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function escAttr(s) {
        return esc(s).replace(/'/g, '&#39;');
    }

    function stripAnsi(s) {
        return s.replace(/\x1b\[[0-9;]*[mGKHF]/g, '');
    }

    <?php if ($this->configured): ?>loadForms();<?php endif; ?>

    return { open, close, run };
})();
</script>
