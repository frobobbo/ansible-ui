</div>

<script>
const AH = (() => {
    const PROXY = <?= json_encode($proxyUrl) ?>;
    let currentForm = null;
    let currentFields = [];
    let pollTimer = null;

    // ── API ──────────────────────────────────────────────────────────────────

    async function api(method, endpoint, body = null) {
        const resp = await fetch(PROXY, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ method, endpoint, body }),
        });
        const data = await resp.json();
        if (data.error) throw new Error(data.error);
        return data;
    }

    // ── Forms list ───────────────────────────────────────────────────────────

    async function loadForms() {
        try {
            const forms = await api('GET', '/api/forms');
            renderForms(Array.isArray(forms) ? forms : []);
        } catch (e) {
            document.getElementById('ah-forms-area').innerHTML =
                `<div class="ah-alert ah-alert-error">Failed to load forms: ${esc(e.message)}</div>`;
        }
    }

    function renderForms(forms) {
        const area = document.getElementById('ah-forms-area');
        if (!forms.length) {
            area.innerHTML = '<div class="ah-empty">No forms found. Create forms in Automation Hub first.</div>';
            return;
        }
        area.innerHTML = '<div class="ah-grid">' + forms.map(f => `
            <div class="ah-card">
                <div class="ah-card-name">${esc(f.name)}</div>
                ${f.description ? `<div class="ah-card-desc">${esc(f.description)}</div>` : '<div class="ah-card-desc"></div>'}
                <div class="ah-card-foot">
                    ${f.is_quick_action ? '<span class="ah-badge">Quick Action</span>' : '<span></span>'}
                    <button class="ah-btn ah-btn-primary" onclick="AH.openRunner(${esc(JSON.stringify(f))})">&#9654; Run</button>
                </div>
            </div>
        `).join('') + '</div>';
    }

    // ── Runner ───────────────────────────────────────────────────────────────

    async function openRunner(form) {
        stopPoll();
        currentForm = form;

        document.getElementById('ah-runner-title').textContent = form.name;
        document.getElementById('ah-fields').innerHTML = '<div class="ah-empty"><span class="ah-spinner"></span>&nbsp; Loading fields…</div>';
        document.getElementById('ah-output').style.display = 'none';
        document.getElementById('ah-run-status').innerHTML = '';
        document.getElementById('ah-run-btn').disabled = false;
        document.getElementById('ah-runner').style.display = '';
        document.getElementById('ah-runner').scrollIntoView({ behavior: 'smooth', block: 'start' });

        try {
            const fields = await api('GET', `/api/forms/${form.id}/fields`);
            currentFields = Array.isArray(fields) ? fields : [];
            renderFields(currentFields);
        } catch (e) {
            document.getElementById('ah-fields').innerHTML =
                `<div class="ah-alert ah-alert-error">Failed to load fields: ${esc(e.message)}</div>`;
        }
    }

    function renderFields(fields) {
        const el = document.getElementById('ah-fields');
        if (!fields.length) {
            el.innerHTML = '<p style="color:#64748b;font-size:.9rem;margin:0">No input fields — click Run to execute with defaults.</p>';
            return;
        }
        el.innerHTML = fields.map(f => {
            const req = f.required ? '<span style="color:#e11d48"> *</span>' : '';
            if (f.field_type === 'bool') {
                return `<div class="ah-field">
                    <div class="ah-field-bool">
                        <input type="checkbox" id="f_${f.id}" ${f.default_value === 'true' ? 'checked' : ''}>
                        <label for="f_${f.id}" style="text-transform:none;font-size:.9rem">${esc(f.label)}${req}</label>
                    </div>
                </div>`;
            }
            if (f.field_type === 'select') {
                let opts = [];
                try { opts = JSON.parse(f.options); } catch(_) {}
                return `<div class="ah-field">
                    <label for="f_${f.id}">${esc(f.label)}${req}</label>
                    <select id="f_${f.id}">${opts.map(o => `<option value="${esc(o)}" ${o === f.default_value ? 'selected' : ''}>${esc(o)}</option>`).join('')}</select>
                </div>`;
            }
            return `<div class="ah-field">
                <label for="f_${f.id}">${esc(f.label)}${req}</label>
                <input type="${f.field_type === 'number' ? 'number' : 'text'}" id="f_${f.id}"
                    value="${esc(f.default_value)}" ${f.required ? 'required' : ''}>
            </div>`;
        }).join('');
    }

    function closeRunner() {
        stopPoll();
        document.getElementById('ah-runner').style.display = 'none';
        currentForm = null;
        currentFields = [];
    }

    // ── Run ──────────────────────────────────────────────────────────────────

    async function runForm() {
        if (!currentForm) return;
        stopPoll();

        // Collect field values
        const variables = {};
        for (const f of currentFields) {
            const el = document.getElementById('f_' + f.id);
            if (!el) continue;
            if (f.field_type === 'bool') {
                variables[f.name] = el.checked ? 'true' : 'false';
            } else {
                const v = el.value.trim();
                if (f.required && v === '') { el.focus(); return; }
                variables[f.name] = v;
            }
        }

        const btn = document.getElementById('ah-run-btn');
        btn.disabled = true;
        setStatus('pending', 'Starting…');

        const outputEl = document.getElementById('ah-output');
        const outputText = document.getElementById('ah-output-text');
        outputEl.style.display = '';
        outputText.textContent = '';

        try {
            const res = await api('POST', '/api/runs', { form_id: currentForm.id, variables });
            pollRun(res.run_id);
        } catch (e) {
            setStatus('failed', 'Error: ' + e.message);
            btn.disabled = false;
        }
    }

    function pollRun(runId) {
        pollTimer = setInterval(async () => {
            try {
                const run = await api('GET', `/api/runs/${runId}`);
                document.getElementById('ah-output-text').textContent = stripAnsi(run.output || '');

                const done = run.status === 'success' || run.status === 'failed';
                setStatus(run.status, run.status.charAt(0).toUpperCase() + run.status.slice(1));
                document.getElementById('ah-output-status').textContent = run.status;

                if (done) {
                    stopPoll();
                    document.getElementById('ah-run-btn').disabled = false;
                }
            } catch (_) { /* keep polling */ }
        }, 2000);
    }

    function stopPoll() {
        if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
    }

    function setStatus(state, text) {
        const el = document.getElementById('ah-run-status');
        el.className = 'ah-status ah-status-' + state;
        el.textContent = text;
    }

    // ── Utilities ────────────────────────────────────────────────────────────

    function esc(s) {
        if (typeof s !== 'string') return String(s);
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // Strip ANSI escape codes from Ansible output
    function stripAnsi(str) {
        return str.replace(/\x1b\[[0-9;]*[mGKHF]/g, '');
    }

    // Bootstrap on load
    loadForms();

    return { openRunner, closeRunner, runForm };
})();
</script>
