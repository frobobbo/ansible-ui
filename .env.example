# ── Required in production ────────────────────────────────────────────────────

# Secret used to sign JWT tokens AND derive the vault/SSH-key encryption key.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Password for the built-in admin account (set on first run; changing it after
# the first boot requires updating the user via the UI or DB directly).
ADMIN_PASSWORD=admin

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the backend listens on (default: 8080).
PORT=8080

# Restrict CORS to your actual domain. Leave unset (or *) for local dev.
# Example: https://ansible.example.com
CORS_ORIGIN=*

# SMTP settings for email notifications on run completion.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=ansible@example.com
